{
  "manifest_version": 3,
  "name": "SVG Vault",
  "version": "1.0.0",
  "description": "Paste SVG code, preview it, override color & size, then download as SVG or PNG.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["downloads"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
